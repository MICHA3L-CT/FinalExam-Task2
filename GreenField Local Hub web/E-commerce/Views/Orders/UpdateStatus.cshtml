@model E_commerce.Models.Order
@* Form for producers and admins to update the status of an order. *@
@{
    ViewData["Title"] = "Update Order Status";
    bool isAdmin = User.IsInRole("Admin");
}
@section Styles {
    <link rel="stylesheet" href="~/css/Orders/Order.css" asp-append-version="true" />
}

<div class="orders-page">
    <div class="orders-container" style="max-width:520px;">

        <div class="order-detail-back">
            <a asp-action="Index" class="order-detail-back__link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
                Back to Orders
            </a>
        </div>

        <h1 class="orders-title">
            Update Status
            <span style="color:#2F6F4E;">#GLH-@Model.OrderId.ToString("D4")</span>
        </h1>

        <div class="order-detail-section" style="margin-top:24px;">

            <dl class="order-detail-dl" style="margin-bottom:24px;">
                <dt>Order Date</dt>
                <dd>@Model.OrderDate.ToString("d MMMM yyyy")</dd>
                <dt>Current Status</dt>
                <dd>
                    <span class="status-badge status-badge--@Model.OrderStatus?.ToLower()">
                        @Model.OrderStatus
                    </span>
                </dd>
                <dt>Total</dt>
                <dd><strong>£@Model.TotalAmount.ToString("0.00")</strong></dd>
            </dl>

            <form asp-action="UpdateStatus" asp-route-id="@Model.OrderId" method="post">
                @Html.AntiForgeryToken()

                <div style="margin-bottom:24px;">
                    <label for="orderStatus" style="display:block;font-size:0.85rem;font-weight:600;color:var(--text-primary,#1a1a1a);margin-bottom:8px;">
                        New Status
                    </label>
                    <select id="orderStatus" name="orderStatus" asp-for="@Model.OrderStatus"
                            style="width:100%;padding:11px 14px;border:1px solid var(--border,#e5e7eb);border-radius:8px;font-size:0.9rem;background:var(--surface,#fff);color:var(--text-primary,#1a1a1a);outline:none;cursor:pointer;">
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Shipped">Shipped</option>
                        <option value="Delivered">Delivered</option>
                        @if (isAdmin)
                        {
                            <option value="Cancelled">Cancelled</option>
                        }
                    </select>
                </div>

                <div style="display:flex;gap:12px;">
                    <button type="submit" class="btn-primary">Save Status</button>
                    <a asp-action="Index" class="btn-secondary">Cancel</a>
                </div>
            </form>
        </div>

    </div>
</div>