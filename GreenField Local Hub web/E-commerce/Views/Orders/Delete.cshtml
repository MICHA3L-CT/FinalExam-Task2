@model E_commerce.Models.Order
@{
    ViewData["Title"] = "Delete Order";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Orders/Order.css" asp-append-version="true" />
}

<div class="orders-page">
    <div class="orders-container" style="max-width:560px;">

        <div class="order-detail-back">
            <a asp-action="Index" class="order-detail-back__link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                Back to Orders
            </a>
        </div>

        <div class="order-detail-section" style="margin-top:24px; border-left:4px solid #dc2626;">
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
                <div style="width:48px;height:48px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </div>
                <div>
                    <h1 class="orders-title" style="margin:0;font-size:1.3rem;">Delete Order</h1>
                    <p style="color:var(--text-secondary,#6b6b6b);font-size:0.85rem;margin:0;">This action cannot be undone.</p>
                </div>
            </div>

            <dl class="order-detail-dl" style="margin-bottom:28px;">
                <dt>Order ID</dt><dd><strong>#GLH-@Model.OrderId.ToString("D4")</strong></dd>
                <dt>Date</dt><dd>@Model.OrderDate.ToString("d MMMM yyyy")</dd>
                <dt>Status</dt>
                <dd>
                    <span class="status-badge status-badge--@Model.OrderStatus?.ToLower()">@Model.OrderStatus</span>
                </dd>
                <dt>Total</dt><dd><strong>£@Model.TotalAmount.ToString("0.00")</strong></dd>
                @if (!string.IsNullOrEmpty(Model.DeliveryType))
                {
                    <dt>Delivery</dt><dd>@Model.DeliveryType</dd>
                }
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="OrderId" />
                <div style="display:flex;gap:12px;">
                    <button type="submit" style="padding:11px 24px;background:#dc2626;color:#fff;border:none;border-radius:8px;font-size:0.9rem;font-weight:700;cursor:pointer;transition:background 0.2s;"
                            onmouseover="this.style.background='#b91c1c'" onmouseout="this.style.background='#dc2626'">
                        Yes, Delete Order
                    </button>
                    <a asp-action="Index" class="btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
