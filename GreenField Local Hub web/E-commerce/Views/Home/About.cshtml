@* Static About Us page - no model needed, content is hardcoded. *@
@{
    ViewData["Title"] = "About Us";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Home/Home.css" />
    <style>
        .about-hero {
            background: linear-gradient(135deg, #2F6F4E 0%, #4a9465 100%);
            color: #fff;
            padding: 80px 24px;
            text-align: center;
        }
        .about-hero h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 16px; }
        .about-hero p { font-size: 1.1rem; opacity: 0.9; max-width: 560px; margin: 0 auto; }
        .about-section { max-width: 860px; margin: 0 auto; padding: 64px 24px; }
        .about-section h2 { font-size: 1.6rem; font-weight: 700; color: var(--text-primary, #1a1a1a); margin-bottom: 14px; }
        .about-section p { color: var(--text-secondary, #6b6b6b); line-height: 1.7; margin-bottom: 16px; }
        .about-values { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 40px; }
        .about-value { background: var(--surface, #fff); border: 1px solid var(--border, #e5e7eb); border-radius: 12px; padding: 24px; text-align: center; }
        .about-value__icon { font-size: 2rem; margin-bottom: 10px; }
        .about-value h3 { font-size: 1rem; font-weight: 700; color: var(--text-primary, #1a1a1a); margin-bottom: 6px; }
        .about-value p { font-size: 0.85rem; color: var(--text-secondary, #6b6b6b); margin: 0; }
    </style>
}

@* Hero banner section *@
<section class="about-hero">
    <h1>About Greenfield Local Hub</h1>
    <p>We connect communities with local farmers to bring fresh, sustainable produce directly to your door.</p>
</section>

@* Main content - company story, mission and values grid *@
<div class="about-section">
    <h2>Our Story</h2>
    <p>Greenfield Local Hub was founded in 2020 with a simple mission: to make locally grown food accessible to everyone while supporting the farmers who grow it.</p>
    <p>We work directly with farms within 50 miles of your delivery address, ensuring produce is at its freshest when it reaches you. No warehouses, no long supply chains — just farm to front door.</p>

    <h2 style="margin-top:40px;">Our Mission</h2>
    <p>We believe that eating locally is better for communities, the environment, and your health. By choosing Greenfield, you're supporting independent farmers and reducing food miles.</p>

    @* Four value cards displayed in a responsive grid *@
    <div class="about-values">
        <div class="about-value">
            <div class="about-value__icon">🌿</div>
            <h3>Sustainability</h3>
            <p>From the farm, straight to your door, supporting sustainable and organic farming practices.</p>
        </div>
        <div class="about-value">
            <div class="about-value__icon">🤝</div>
            <h3>Community</h3>
            <p>Building direct relationships between growers and consumers across the local area.</p>
        </div>
        <div class="about-value">
            <div class="about-value__icon">⭐</div>
            <h3>Quality</h3>
            <p>Only the freshest, highest quality produce sourced from trusted local farms.</p>
        </div>
        <div class="about-value">
            <div class="about-value__icon">🌾</div>
            <h3>Transparency</h3>
            <p>Know exactly where your food comes from and who grew it for you.</p>
        </div>
    </div>
</div>
