@{
    ViewData["Title"] = "Loyalty Programme";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Loyalty/Loyalty.css" asp-append-version="true" />
}

<div class="loyalty-page">

    <!-- Hero -->
    <section class="loyalty-hero">
        <div class="loyalty-hero__inner">
            <div class="loyalty-hero__badge" aria-hidden="true">⭐</div>
            <h1 class="loyalty-hero__title">GreenField Loyalty Programme</h1>
            <p class="loyalty-hero__sub">Earn rewards every time you shop local</p>
            @if (!User.Identity?.IsAuthenticated ?? true)
            {
                <div class="loyalty-hero__cta">
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn-loyalty-cta">Join Free Today</a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-loyalty-secondary">Already a member? Log in</a>
                </div>
            }
            else
            {
                <div class="loyalty-hero__cta">
                    <a asp-controller="Products" asp-action="Index" class="btn-loyalty-cta">Shop Now to Earn</a>
                </div>
            }
        </div>
    </section>

    <!-- How It Works -->
    <section class="loyalty-how">
        <div class="loyalty-container">
            <h2 class="loyalty-section-title">How It Works</h2>
            <p class="loyalty-section-sub">Three simple steps to start saving</p>
            <div class="loyalty-steps">
                <div class="loyalty-step">
                    <div class="loyalty-step__num" aria-hidden="true">1</div>
                    <div class="loyalty-step__icon" aria-hidden="true">🛒</div>
                    <h3>Shop</h3>
                    <p>Place an order through GreenField Local Hub. Every qualifying order counts toward your loyalty discount.</p>
                </div>
                <div class="loyalty-step__connector" aria-hidden="true">→</div>
                <div class="loyalty-step">
                    <div class="loyalty-step__num" aria-hidden="true">2</div>
                    <div class="loyalty-step__icon" aria-hidden="true">📦</div>
                    <h3>Collect</h3>
                    <p>Your orders are tracked automatically in your account. After every 5 completed orders your discount unlocks.</p>
                </div>
                <div class="loyalty-step__connector" aria-hidden="true">→</div>
                <div class="loyalty-step">
                    <div class="loyalty-step__num" aria-hidden="true">3</div>
                    <div class="loyalty-step__icon" aria-hidden="true">🎉</div>
                    <h3>Save</h3>
                    <p>Enjoy 10% off your entire basket automatically applied at checkout — no codes needed!</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Progress Demo (interactive) -->
    <section class="loyalty-demo" aria-labelledby="progress-heading">
        <div class="loyalty-container">
            <h2 class="loyalty-section-title" id="progress-heading">Your Progress Tracker</h2>
            <p class="loyalty-section-sub">Here's what your loyalty journey looks like</p>
            <div class="loyalty-demo-card">
                <div class="loyalty-demo__header">
                    <span class="loyalty-demo__label">Orders toward next 10% discount</span>
                    <span class="loyalty-demo__count" id="demoCount">3 / 5</span>
                </div>
                <div class="loyalty-progress-track" role="progressbar" aria-valuenow="3" aria-valuemin="0" aria-valuemax="5" id="demoTrack">
                    <div class="loyalty-progress-fill" id="demoFill" style="width:60%"></div>
                    <div class="loyalty-progress-dots">
                        <span class="loyalty-dot loyalty-dot--done" aria-label="Order 1 complete">1</span>
                        <span class="loyalty-dot loyalty-dot--done" aria-label="Order 2 complete">2</span>
                        <span class="loyalty-dot loyalty-dot--done" aria-label="Order 3 complete">3</span>
                        <span class="loyalty-dot" aria-label="Order 4 pending">4</span>
                        <span class="loyalty-dot" aria-label="Order 5 pending">5</span>
                    </div>
                </div>
                <p class="loyalty-demo__msg">Just <strong>2 more orders</strong> to unlock your 10% discount!</p>
                <div class="loyalty-demo__controls">
                    <button class="btn-demo" id="demoSimulate">Simulate next order ▶</button>
                    <button class="btn-demo btn-demo--reset" id="demoReset">Reset</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits -->
    <section class="loyalty-benefits">
        <div class="loyalty-container">
            <h2 class="loyalty-section-title">Programme Benefits</h2>
            <div class="loyalty-benefit-grid">
                <div class="loyalty-benefit-card">
                    <span class="loyalty-benefit__icon" aria-hidden="true">💰</span>
                    <h3>10% Off Every 5 Orders</h3>
                    <p>Your discount is automatically applied at checkout — no voucher codes needed.</p>
                </div>
                <div class="loyalty-benefit-card">
                    <span class="loyalty-benefit__icon" aria-hidden="true">🔄</span>
                    <h3>Resets Automatically</h3>
                    <p>Once you've used your discount, the counter resets and you start earning again immediately.</p>
                </div>
                <div class="loyalty-benefit-card">
                    <span class="loyalty-benefit__icon" aria-hidden="true">🌿</span>
                    <h3>Supports Local Farmers</h3>
                    <p>Every purchase goes directly to local producers in your community.</p>
                </div>
                <div class="loyalty-benefit-card">
                    <span class="loyalty-benefit__icon" aria-hidden="true">🚚</span>
                    <h3>Free Delivery Progress</h3>
                    <p>The more you order, the better your rewards. Watch your savings grow over time.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQs -->
    <section class="loyalty-faq">
        <div class="loyalty-container loyalty-container--narrow">
            <h2 class="loyalty-section-title">Frequently Asked Questions</h2>
            <div class="faq-list" id="faqList">
                <div class="faq-item">
                    <button class="faq-question" aria-expanded="false">
                        How do I join the loyalty programme?
                        <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="faq-answer" hidden>
                        <p>Simply create a free account on GreenField Local Hub. Your loyalty progress starts tracking automatically from your very first order.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" aria-expanded="false">
                        When does the 10% discount apply?
                        <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="faq-answer" hidden>
                        <p>Once you have completed 5 qualifying orders, the 10% discount is automatically applied to your next order at checkout — no action needed on your part.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" aria-expanded="false">
                        Does the discount expire?
                        <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="faq-answer" hidden>
                        <p>Your earned discount does not expire. It will be applied to your next basket once you've reached the 5-order threshold.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" aria-expanded="false">
                        Can I see my loyalty progress?
                        <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="faq-answer" hidden>
                        <p>Yes! Your loyalty progress is shown in your basket whenever you have items added. You'll see a progress bar and how many orders remain until your next discount.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <section class="loyalty-cta-section">
            <h2>Ready to start saving?</h2>
            <p>Join thousands of customers already enjoying the benefits of shopping local.</p>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn-loyalty-cta">Create Your Free Account</a>
        </section>
    }

</div>

@section Scripts {
    <script>
        // FAQ accordion
        document.querySelectorAll('.faq-question').forEach(btn => {
            btn.addEventListener('click', () => {
                const isOpen = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', (!isOpen).toString());
                const answer = btn.nextElementSibling;
                if (isOpen) { answer.hidden = true; }
                else { answer.hidden = false; }
            });
        });

        // Demo simulator
        let demoOrders = 3;
        const MAX = 5;

        function updateDemo() {
            const pct = (demoOrders / MAX) * 100;
            document.getElementById('demoFill').style.width = pct + '%';
            document.getElementById('demoCount').textContent = demoOrders + ' / ' + MAX;
            const track = document.getElementById('demoTrack');
            track.setAttribute('aria-valuenow', demoOrders);
            document.querySelectorAll('.loyalty-dot').forEach((dot, i) => {
                if (i < demoOrders) dot.classList.add('loyalty-dot--done');
                else dot.classList.remove('loyalty-dot--done');
            });
            const msg = document.querySelector('.loyalty-demo__msg');
            if (demoOrders >= MAX) {
                msg.innerHTML = '<strong>🎉 Discount unlocked!</strong> Your 10% loyalty discount has been applied to your basket.';
            } else {
                const rem = MAX - demoOrders;
                msg.innerHTML = 'Just <strong>' + rem + ' more order' + (rem > 1 ? 's' : '') + '</strong> to unlock your 10% discount!';
            }
        }

        document.getElementById('demoSimulate')?.addEventListener('click', () => {
            if (demoOrders < MAX) { demoOrders++; updateDemo(); }
        });

        document.getElementById('demoReset')?.addEventListener('click', () => {
            demoOrders = 0; updateDemo();
        });
    </script>
}
