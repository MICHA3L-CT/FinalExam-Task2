@model E_commerce.Models.Product

@{
    ViewData["Title"] = "Add New Product";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Products/Products.css" asp-append-version="true" />
}

<div class="product-form-page">
    <div class="product-form-container">

        <div class="product-form-back">
            <a asp-action="Index" class="product-form-back__link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                Back to Products
            </a>
        </div>

        <div class="product-form-header">
            <div class="product-form-header__icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3H8l-2 4h12l-2-4z"/></svg>
            </div>
            <div>
                <h1 class="product-form-title">Add New Product</h1>
                <p class="product-form-subtitle">Fill in the details below to list a new product</p>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="product-form-errors" role="alert"></div>

        <form asp-action="Create" class="product-form">
            <div class="product-form-grid">

                <div class="form-field">
                    <label asp-for="ProducerId" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Producer
                    </label>
                    <select asp-for="ProducerId" class="form-field__select" asp-items="ViewBag.ProducerId">
                        <option value="">-- Select Producer --</option>
                    </select>
                    <span asp-validation-for="ProducerId" class="form-field__error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="ProductName" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
                        Product Name
                    </label>
                    <input asp-for="ProductName" class="form-field__input" placeholder="e.g. Organic Strawberries" />
                    <span asp-validation-for="ProductName" class="form-field__error"></span>
                </div>

                <div class="form-field form-field--full">
                    <label asp-for="Description" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                        Description
                    </label>
                    <textarea asp-for="Description" class="form-field__textarea" rows="3" placeholder="Describe your product..."></textarea>
                    <span asp-validation-for="Description" class="form-field__error"></span>
                </div>

                <div class="form-field form-field--full">
                    <label asp-for="ImagePath" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        Image URL
                    </label>
                    <input asp-for="ImagePath" class="form-field__input" placeholder="https://example.com/image.jpg" />
                    <span asp-validation-for="ImagePath" class="form-field__error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Price" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        Price (£)
                    </label>
                    <div class="form-field__input-wrap">
                        <span class="form-field__prefix">£</span>
                        <input asp-for="Price" class="form-field__input form-field__input--prefix" type="number" step="0.01" min="0" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Price" class="form-field__error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="StockQuantity" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 8h14M5 8a2 2 0 1 0-4 0v12a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8m-14 0V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        Stock Quantity
                    </label>
                    <input asp-for="StockQuantity" class="form-field__input" type="number" min="0" placeholder="0" />
                    <span asp-validation-for="StockQuantity" class="form-field__error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Category" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                        Category
                    </label>
                    <input asp-for="Category" class="form-field__input" placeholder="e.g. Fruit & Veg" />
                    <span asp-validation-for="Category" class="form-field__error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="DateAdded" class="form-field__label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Date Added
                    </label>
                    <input asp-for="DateAdded" class="form-field__input" type="datetime-local" />
                    <span asp-validation-for="DateAdded" class="form-field__error"></span>
                </div>

            </div>

            <div class="product-form-actions">
                <button type="submit" class="btn-primary product-form-submit">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    Create Product
                </button>
                <a asp-action="Index" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
