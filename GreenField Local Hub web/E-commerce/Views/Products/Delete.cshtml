@model E_commerce.Models.Product
@* Confirmation page before a producer permanently deletes one of their products. *@
@* Styled to match the rest of the site using Products.css design tokens. *@

@{
    ViewData["Title"] = "Delete Product"; @* Sets the browser tab title *@
}

@* Load Products.css so all CSS variables (colours, radii, shadows) are available *@
@section Styles {
    <link rel="stylesheet" href="~/css/Products/Products.css" asp-append-version="true" />
    <style>
        /* ── Product delete confirmation page ───────────────────── */

        /* Narrow centred layout so the card doesn't feel lost on wide screens */
        .delete-page {
            max-width: 640px;
            margin: 60px auto;
            padding: 0 24px 80px;
        }

        /* Back link above the card */
        .delete-back { margin-bottom: 24px; }

        .delete-back__link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.2s;
        }
            .delete-back__link:hover { color: var(--accent); }

        /* White card with rounded corners and shadow */
        .delete-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

        /* Red warning strip at the top - immediately signals a destructive action */
        .delete-card__banner {
            background: #FDE8E8;
            border-bottom: 1px solid #FCCACA;
            padding: 20px 28px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        /* Circular icon background inside the red banner */
        .delete-card__banner-icon {
            width: 42px; height: 42px;
            background: #FCA5A5;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: #991B1B;
        }

        /* Bold red heading in the banner */
        .delete-card__banner-title { font-size: 1.1rem; font-weight: 700; color: #991B1B; }

        /* Smaller orange warning subtitle */
        .delete-card__banner-sub { font-size: 0.83rem; color: #B45309; margin-top: 2px; }

        /* Padding inside the card body */
        .delete-card__body { padding: 28px; }

        /* Optional product image fills the full width */
        .delete-product-img {
            width: 100%; max-height: 200px;
            object-fit: cover;
            border-radius: var(--radius-md);
            margin-bottom: 24px;
            border: 1px solid var(--border);
        }

        /* Container for the label/value detail rows */
        .delete-detail-grid { display: grid; gap: 0; margin-bottom: 0; }

        /* Each row holds one piece of product information */
        .delete-detail-row {
            display: flex; gap: 12px;
            align-items: flex-start;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }
            /* No border under the last row to avoid doubling with the footer border */
            .delete-detail-row:last-child { border-bottom: none; }

        /* Fixed-width uppercase label on the left */
        .delete-detail-label {
            font-size: 0.8rem; font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase; letter-spacing: 0.04em;
            width: 120px; flex-shrink: 0; padding-top: 2px;
        }

        /* Value takes the remaining space */
        .delete-detail-value { font-size: 0.95rem; color: var(--text-primary); font-weight: 500; flex: 1; }

        /* Green chip for the category field - same style as the products index page */
        .delete-tag {
            display: inline-block; padding: 3px 10px;
            border-radius: 999px; font-size: 0.78rem; font-weight: 600;
            background: var(--accent-muted); color: var(--accent);
        }

        /* Footer row containing the Cancel and Delete buttons */
        .delete-card__footer {
            border-top: 1px solid var(--border);
            padding: 20px 28px;
            display: flex; gap: 12px;
            justify-content: flex-end; flex-wrap: wrap;
        }

        /* Cancel - neutral outline so it doesn't visually compete with the delete button */
        .btn-cancel {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 10px 22px; border-radius: var(--radius-sm);
            border: 1px solid var(--border); background: var(--surface);
            color: var(--text-secondary); font-size: 0.9rem; font-weight: 600;
            text-decoration: none; cursor: pointer; transition: var(--transition);
        }
            .btn-cancel:hover { background: var(--surface-hover); color: var(--text-primary); }

        /* Delete - solid red so the user clearly sees it's a destructive action */
        .btn-delete-confirm {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 10px 22px; border-radius: var(--radius-sm);
            border: none; background: #DC2626; color: #fff;
            font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: var(--transition);
        }
            .btn-delete-confirm:hover {
                background: #B91C1C;
                transform: translateY(-1px); /* Subtle lift on hover */
                box-shadow: 0 4px 14px rgba(220,38,38,0.35);
            }
    </style>
}

<div class="delete-page">

    <!-- Back link - returns the user to the products list without deleting -->
    <div class="delete-back">
        <a asp-action="Index" class="delete-back__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to Products
        </a>
    </div>

    <div class="delete-card">

        <!-- Red banner: icon + title + warning subtitle -->
        <div class="delete-card__banner" role="alert">
            @* aria-hidden prevents screen readers from narrating the raw SVG paths *@
            <div class="delete-card__banner-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6"/><path d="M14 11v6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                </svg>
            </div>
            <div>
                <div class="delete-card__banner-title">Delete Product</div>
                <div class="delete-card__banner-sub">This action cannot be undone</div>
            </div>
        </div>

        <!-- Product details so the user can confirm they're deleting the right item -->
        <div class="delete-card__body">

            @* Only render the image element if an image path has been saved for this product *@
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Url.Content(Model.ImagePath)" alt="@Model.ProductName" class="delete-product-img" />
            }

            <div class="delete-detail-grid">

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Name</span>
                    <span class="delete-detail-value">@Model.ProductName</span>
                </div>

                @* Only show description if one has been entered *@
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="delete-detail-row">
                        <span class="delete-detail-label">Description</span>
                        <span class="delete-detail-value">@Model.Description</span>
                    </div>
                }

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Category</span>
                    <span class="delete-detail-value">
                        @* Chip style matching the category tags on the products index page *@
                        <span class="delete-tag">@Model.Category</span>
                    </span>
                </div>

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Price</span>
                    @* Format as currency with exactly two decimal places *@
                    <span class="delete-detail-value">£@Model.Price.ToString("0.00")</span>
                </div>

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Stock</span>
                    <span class="delete-detail-value">@Model.StockQuantity units</span>
                </div>

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Added</span>
                    @* Human-readable date format e.g. "05 Apr 2025" *@
                    <span class="delete-detail-value">@Model.DateAdded.ToString("dd MMM yyyy")</span>
                </div>

            </div>
        </div>

        <!-- Action buttons row -->
        <div class="delete-card__footer">

            @* Cancel - navigates away without deleting *@
            <a asp-action="Index" class="btn-cancel">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
                Cancel
            </a>

            @* Confirm delete form - the hidden field carries the product ID to the controller *@
            <form asp-action="Delete" style="display:inline;">
                <input type="hidden" asp-for="ProductId" />
                <button type="submit" class="btn-delete-confirm">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6"/><path d="M14 11v6"/>
                    </svg>
                    Yes, Delete Product
                </button>
            </form>

        </div>
    </div>
</div>
