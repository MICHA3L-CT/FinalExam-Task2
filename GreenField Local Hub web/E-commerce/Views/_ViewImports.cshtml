@* Imports applied to every view in the project. *@
@* Makes the E_commerce and E_commerce.Models namespaces available without needing @using in each file. *@
@* AddTagHelper enables all built-in ASP.NET Core tag helpers (asp-for, asp-controller, asp-action etc.) *@
@using E_commerce
@using E_commerce.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
