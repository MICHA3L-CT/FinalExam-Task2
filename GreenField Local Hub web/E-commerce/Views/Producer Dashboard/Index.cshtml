@model IEnumerable<E_commerce.Models.Product>

@{
    ViewData["Title"] = "Supplier Dashboard";

    var recentOrders = ViewBag.RecentOrders as List<E_commerce.Models.Order> ?? new List<E_commerce.Models.Order>();
    var producer = ViewBag.Producer;
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Supplier Dashboard</h1>

        <a asp-action="Create" asp-controller="Products" class="btn btn-primary">
            + Add New Product
        </a>
    </div>

    <!-- Producer Info (safe) -->
    @if (producer != null)
    {
        <div class="alert alert-info mb-4">
            <strong>@producer.ProducerName</strong> |
            @producer.Location
        </div>
    }

    <!-- Stats Cards -->
    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Products</h5>
                    <p class="card-text display-6">@Model?.Count() ?? 0</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Recent Orders</h5>
                    <p class="card-text display-6">@recentOrders.Count</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Recent Orders -->
    <h2 class="mt-4 mb-3">📦 Recent Orders</h2>

    @if (!recentOrders.Any())
    {
        <div class="alert alert-warning">
            No recent orders found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in recentOrders)
                    {
                        <tr>
                            <td>@order.OrderId</td>

                            <td>
                                @order.OrderDate.ToString("yyyy-MM-dd")
                            </td>

                            <td>
                                <span class="badge bg-@(
                                order.OrderStatus == "Completed" ? "success" :
                                order.OrderStatus == "Pending" ? "warning" :
                                order.OrderStatus == "Cancelled" ? "danger" :
                                "secondary")">
                                    @order.OrderStatus
                                </span>
                            </td>

                            <td>
                                @order.TotalAmount.ToString("C")
                            </td>

                            <td>
                                <a asp-action="Details"
                                   asp-controller="Orders"
                                   asp-route-id="@order.OrderId"
                                   class="btn btn-sm btn-info">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    }

    <!-- Products -->
    <h2 class="mt-5 mb-3">🛍️ Your Products</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered">

                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Category</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>@product.ProductId</td>

                            <td>
                                @(product.ProductName ?? "Unnamed Product")
                            </td>

                            <td>
                                @product.Price.ToString("C")
                            </td>

                            <td>
                                @product.StockQuantity
                            </td>

                            <td>
                                @(product.Category ?? "N/A")
                            </td>

                            <td>
                                <a asp-action="Edit"
                                   asp-controller="Products"
                                   asp-route-id="@product.ProductId"
                                   class="btn btn-sm btn-warning">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-controller="Products"
                                   asp-route-id="@product.ProductId"
                                   class="btn btn-sm btn-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You haven't added any products yet.
        </div>
    }

</div>