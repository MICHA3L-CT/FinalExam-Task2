@model IEnumerable<E_commerce.Models.OrderProduct>
@* Lists all order product lines. Admin view. *@

@{
    ViewData["Title"] = "Order Lines"; @* Browser tab title *@
}

<h1>Order Lines</h1>

<p>
    <a asp-action="Create">Create New</a> @* Manual creation for admin corrections *@
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.UnitPrice)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Product)
            </th>
            <th></th> @* Actions column header *@
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.UnitPrice)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Order.OrderId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Product.ProductId)
            </td>
            <td>
                @* Row action links - each passes the primary key as a route value *@
                    <a asp-action="Edit"    asp-route-id="@item.OrderProductId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.OrderProductId">Details</a> |
                    <a asp-action="Delete"  asp-route-id="@item.OrderProductId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
