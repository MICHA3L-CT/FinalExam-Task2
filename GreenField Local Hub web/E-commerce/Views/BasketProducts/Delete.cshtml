@model E_commerce.Models.BasketProduct
@* Confirmation page shown before a basket item is permanently removed. *@
@* The model carries the basket product record including its related Product and Basket. *@

@{
    ViewData["Title"] = "Remove Item"; @* Sets the browser tab title *@
}

@* Pull in the shared Products CSS so colours, tokens and buttons match the rest of the site *@
@section Styles {
    <link rel="stylesheet" href="~/css/Products/Products.css" asp-append-version="true" />
    <style>
        /* ── BasketProduct Delete confirmation page ──────────── */

        /* Outer wrapper - centres the card and gives it breathing room */
        .delete-page {
            max-width: 580px;
            margin: 60px auto;
            padding: 0 24px 80px;
        }

        /* Back link sitting above the card */
        .delete-back {
            margin-bottom: 24px;
        }

        .delete-back__link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.2s;
        }

            .delete-back__link:hover {
                color: var(--accent); /* Turns green on hover to match other links */
            }

        /* White card that contains the warning and details */
        .delete-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

        /* Red banner strip across the top of the card - makes the action feel serious */
        .delete-card__banner {
            background: #FDE8E8;
            border-bottom: 1px solid #FCCACA;
            padding: 20px 28px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        /* Circular icon container inside the red banner */
        .delete-card__banner-icon {
            width: 42px;
            height: 42px;
            background: #FCA5A5;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: #991B1B;
        }

        /* Main heading inside the red banner */
        .delete-card__banner-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #991B1B;
        }

        /* Subtitle below the heading - warns user the action cannot be undone */
        .delete-card__banner-sub {
            font-size: 0.83rem;
            color: #B45309;
            margin-top: 2px;
        }

        /* Padding around the detail rows */
        .delete-card__body {
            padding: 28px;
        }

        /* Container for all label/value rows */
        .delete-detail-grid {
            display: grid;
            gap: 0;
            margin-bottom: 0;
        }

        /* Each row has a label on the left and the value on the right */
        .delete-detail-row {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }

            /* Last row has no bottom border so it doesn't double up with the footer border */
            .delete-detail-row:last-child {
                border-bottom: none;
            }

        /* Small uppercase label column on the left */
        .delete-detail-label {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            width: 110px;
            flex-shrink: 0;
            padding-top: 2px;
        }

        /* Value column taking the remaining space */
        .delete-detail-value {
            font-size: 0.95rem;
            color: var(--text-primary);
            font-weight: 500;
            flex: 1;
        }

        /* Cancel + Confirm buttons row at the bottom of the card */
        .delete-card__footer {
            border-top: 1px solid var(--border);
            padding: 20px 28px;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        /* Cancel button - neutral outline style so it doesn't compete visually */
        .btn-cancel {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-cancel:hover {
                background: var(--surface-hover);
                color: var(--text-primary);
            }

        /* Confirm delete button - solid red so it's clearly the destructive action */
        .btn-delete-confirm {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            border-radius: var(--radius-sm);
            border: none;
            background: #DC2626;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-delete-confirm:hover {
                background: #B91C1C;
                transform: translateY(-1px); /* Subtle lift on hover */
                box-shadow: 0 4px 14px rgba(220,38,38,0.35);
            }
    </style>
}

<div class="delete-page">

    <!-- Back link to the basket -->
    <div class="delete-back">
        @* Link goes back to the basket page, not a generic list *@
        <a asp-controller="Baskets" asp-action="Index" class="delete-back__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to Basket
        </a>
    </div>

    <div class="delete-card">

        <!-- Red warning banner -->
        <div class="delete-card__banner" role="alert">
            @* aria-hidden on the icon so screen readers don't read out the SVG paths *@
            <div class="delete-card__banner-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6"/><path d="M14 11v6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                </svg>
            </div>
            <div>
                <div class="delete-card__banner-title">Remove from Basket</div>
                <div class="delete-card__banner-sub">Are you sure you want to remove this item?</div>
            </div>
        </div>

        <!-- Item details so the user can confirm they're removing the right thing -->
        <div class="delete-card__body">
            <div class="delete-detail-grid">

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Product</span>
                    @* Show the product name if the navigation property loaded, otherwise fall back to the ID *@
                    <span class="delete-detail-value">@(Model.Product?.ProductName ?? $"Product #{Model.ProductId}")</span>
                </div>

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Quantity</span>
                    <span class="delete-detail-value">@Model.Quantity unit@(Model.Quantity == 1 ? "" : "s")</span>
                </div>

                <div class="delete-detail-row">
                    <span class="delete-detail-label">Line Total</span>
                    @* Format as GBP with two decimal places *@
                    <span class="delete-detail-value">£@Model.TotalPrice.ToString("0.00")</span>
                </div>

            </div>
        </div>

        <!-- Action buttons -->
        <div class="delete-card__footer">

            @* Cancel goes back to basket without deleting anything *@
            <a asp-controller="Baskets" asp-action="Index" class="btn-cancel">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
                Cancel
            </a>

            @* The hidden field carries the ID so the controller knows which record to delete *@
            <form asp-action="Delete" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BasketProductId" />
                <button type="submit" class="btn-delete-confirm">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6"/><path d="M14 11v6"/>
                    </svg>
                    Yes, Remove Item
                </button>
            </form>

        </div>
    </div>
</div>
