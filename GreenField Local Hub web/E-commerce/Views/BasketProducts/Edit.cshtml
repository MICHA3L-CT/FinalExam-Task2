@model E_commerce.Models.BasketProduct
@* Form to edit a basket product record. Admin use only. *@

@{
    ViewData["Title"] = "Edit Basket Product"; @* Browser tab title *@
}

<h1>Edit</h1>

<h4>BasketProduct</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            @* Show model-level validation errors at the top of the form *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Hidden field carries the primary key so the controller can find the right record *@
            <input type="hidden" asp-for="BasketProductId" />

            <div class="form-group">
                <label asp-for="ProductId" class="control-label"></label>
                @* Dropdown pre-selected with the current ProductId *@
                <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductId"></select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="BasketId" class="control-label"></label>
                @* Dropdown pre-selected with the current BasketId *@
                <select asp-for="BasketId" class="form-control" asp-items="ViewBag.BasketId"></select>
                <span asp-validation-for="BasketId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TotalPrice" class="control-label"></label>
                @* Should equal Quantity x Product.Price - update manually if correcting a record *@
                <input asp-for="TotalPrice" class="form-control" />
                <span asp-validation-for="TotalPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@* Load jQuery validation scripts for client-side field validation *@
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
