@model E_commerce.Models.Discount
@* Shows details of a single discount code. *@

@{
    ViewData["Title"] = "Discount Details"; @* Browser tab title *@
}

<h1>Details</h1>

<div>
    <h4>Discount</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Code)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Code)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DiscountPercentage)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DiscountPercentage)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ExpiryDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ExpiryDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.MaxUses)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaxUses)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UsedCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UsedCount)
        </dd>
    </dl>
</div>
<div>
    @* Null-conditional ?. guards against a null model *@
    <a asp-action="Edit" asp-route-id="@Model?.DiscountId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
